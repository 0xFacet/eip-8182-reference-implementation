{
  "name": "@eip8182/contracts",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "npm run test:slow",
    "verifier:refresh": "node ../scripts/sync-honk-verifier.mjs",
    "verifier:check": "node ../scripts/sync-honk-verifier.mjs --check",
    "bench:eip712-proofs": "node ../scripts/benchmark-eip712-proofs.mjs",
    "test:unit": "node ../scripts/run-contract-tests.mjs --match-contract 'ShieldedPoolTest|InstallSystemContractsScriptTest'",
    "test:slow": "npm run test:unit && npm run test:real-verifier && npm run test:smoke",
    "test:all": "npm run test:slow && npm run test:fullflow",
    "test:smoke": "node ../scripts/run-contract-tests.mjs --match-path test/SmokeE2E.t.sol",
    "test:smoke:timed": "node ../scripts/run-contract-tests.mjs --ffi-timing --match-path test/SmokeE2E.t.sol -vv",
    "test:fullflow": "node ../scripts/run-contract-tests.mjs --match-path test/FullFlowE2E.t.sol",
    "test:fullflow:timed": "node ../scripts/run-contract-tests.mjs --ffi-timing --match-path test/FullFlowE2E.t.sol -vv",
    "test:e2e": "npm run test:smoke",
    "test:e2e:fullflow": "npm run test:fullflow",
    "test:e2e:all": "npm run test:slow && npm run test:fullflow",
    "test:real-verifier": "node ../scripts/run-contract-tests.mjs --match-contract VerifierPrecompileIntegrationTest -vv",
    "fmt": "forge fmt",
    "install:local": "forge script script/InstallSystemContracts.s.sol:InstallSystemContracts"
  }
}
